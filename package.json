{
  "name": "playwright-electron-poc",
  "version": "1.0.0",
  "description": "Enterprise-grade E2E testing framework for Electron applications using Playwright",
  "main": "index.js",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:debug": "playwright test --debug",
    "test:headed": "playwright test --headed",
    "test:smoke": "playwright test tests/specs/smoke.spec.ts",
    "test:functional": "playwright test tests/specs/functional.spec.ts",
    "allure:report": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "lint": "eslint . --ext .ts",
    "lint:fix": "eslint . --ext .ts --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "build": "tsc",
    "clean": "rm -rf allure-results allure-report dist"
  },
  "keywords": [
    "playwright",
    "electron",
    "e2e",
    "testing",
    "automation"
  ],
  "author": "QA Team",
  "license": "MIT",
  "devDependencies": {
    "@playwright/test": "^1.48.0",
    "electron": "^41.0.0",
    "@types/node": "^22.5.0",
    "@typescript-eslint/eslint-plugin": "^8.3.0",
    "@typescript-eslint/parser": "^8.3.0",
    "allure-playwright": "^3.0.0",
    "eslint": "^9.10.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0"
  },
  "dependencies": {}
}
